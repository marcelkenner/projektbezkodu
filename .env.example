# Production build and runtime settings for projektbezkodu.pl on OVH.
# Set NEXT_PUBLIC_SITE_URL before running `npm run build`; Next.js bakes it into the client bundle.

NEXT_PUBLIC_SITE_URL=https://projektbezkodu.pl
CANONICAL_HOST=projektbezkodu.pl

# Optional homepage hero variant id. Leave empty to use the default variant from content.
NEXT_PUBLIC_HOMEPAGE_HERO_VARIANT=

# Newsletter integration. These values are required only when the newsletter flows should work in production.
LISTMONK_BASE_URL=
LISTMONK_API_TOKEN=
LISTMONK_LIST_ID=
LISTMONK_LIST_UUID=
LISTMONK_TIMEOUT_MS=10000
LISTMONK_RETRY_ATTEMPTS=2
LISTMONK_RETRY_MIN_DELAY_MS=250
LISTMONK_RETRY_MAX_DELAY_MS=2000

# Optional build-time content validation flags.
CONTENT_LINT_STRICT=false
CONTENT_HERO_IMAGES_WARN_ONLY=false
